# Telegram Bot Token（从 @BotFather 获取）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 你的 Telegram User ID（从 @userinfobot 获取，用于白名单验证）
ALLOWED_USER_IDS=123456789

# Claude Code 默认工作目录
WORK_DIR=/Users/your_username/your_project

# 预设项目列表（JSON 格式，name 为显示名称，path 为目录路径）
# 发送 /projects 命令可以列出这些项目并点按钮切换
PROJECTS=[{"name":"项目A","path":"/Users/your_username/project-a"},{"name":"项目B","path":"/Users/your_username/project-b"}]

# 默认 AI 后端（可选：claude / gemini / qwen / codex，默认 claude）
# 在 Telegram 中发送 /ai 可以随时切换
DEFAULT_AI_BACKEND=claude

# Claude CLI 路径（默认自动查找，一般不需要填）
# CLAUDE_BIN=/usr/local/bin/claude

# Gemini CLI 路径（默认自动查找，一般不需要填）
# GEMINI_BIN=/usr/local/bin/gemini

# Qwen Code CLI 路径（默认自动查找，一般不需要填）
# 安装：npm install -g @qwen-code/qwen-code
# QWEN_BIN=/usr/local/bin/qwen

# Codex CLI 路径（默认自动查找，一般不需要填）
# 安装：npm install -g @openai/codex
# CODEX_BIN=/usr/local/bin/codex

# Codex CLI API Key（变量名由 ~/.codex/config.toml 中的 env_key 字段决定，填对应值即可）
OPENAI_API_KEY=your_api_key_here

#  claude code 三方 API 配置（如果使用三方 API，填入对应的 token 和地址）
ANTHROPIC_AUTH_TOKEN=your_api_token_here
ANTHROPIC_BASE_URL=https://your-api-endpoint.com/api

# ngrok authtoken（/tunnel 命令需要，从 https://dashboard.ngrok.com 获取）
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# 代理配置（国内访问 Telegram 必填，填本地代理地址）
HTTPS_PROXY=http://127.0.0.1:7890

# ====== 钉钉 Bot 配置（选填，不配置则不启动钉钉 Bot）======
# 企业内部应用 AppKey 和 AppSecret（在钉钉开放平台 → 应用凭证中获取）
DINGTALK_APP_KEY=dingxxxxxxxxxxxx
DINGTALK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 白名单 staffId（逗号分隔；为空则允许所有人）
DINGTALK_ALLOWED_USER_IDS=staffId1,staffId2

# ====== 飞书 Bot 配置（选填，不配置则不启动飞书 Bot）======
# 飞书应用 App ID 和 App Secret（在飞书开放平台 → 凭证与基础信息中获取）
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 白名单用户 openId（逗号分隔，以 ou_ 开头；为空则允许所有人）
FEISHU_ALLOWED_USER_IDS=ou_xxxxxxxx
# 注：飞书使用 WebSocket 长连接模式，无需公网 IP 和端口配置
